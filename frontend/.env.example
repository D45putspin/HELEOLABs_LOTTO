# Hathor Lottery dApp Configuration

# Network selection
VITE_HATHOR_NETWORK=testnet
VITE_HATHOR_NODE_URL=https://node1.testnet.hathor.network/v1a/

# WalletConnect Project ID - Get yours at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Your deployed lottery blueprint ID on Hathor Network
# This is the transaction ID from when you registered your lottery.py blueprint
VITE_LOTTERY_BLUEPRINT_ID=00000000a2c12868617fe425103cf2738e467041f29f6404434cffb837128a26

# Optional: List of known lottery contract IDs (comma-separated)
# Use this if you want to display specific contracts without querying the indexer
VITE_LOTTERY_CONTRACTS=
